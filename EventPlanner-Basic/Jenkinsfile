pipeline {
    agent any
    tools {
        nodejs 'NodeJS_20' // Ensure this matches your Jenkins global tool config
    }
    environment {
        DOCKER_IMAGE = 'eventplanner-basic:latest'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Install') {
            steps {
                dir('EventPlanner-Basic') {
                    sh 'npm install'
                }
            }
        }
        stage('Lint') {
            steps {
                dir('EventPlanner-Basic') {
                    sh 'npm run lint || echo "Linting skipped"'
                }
            }
        }
        stage('Test') {
            steps {
                dir('EventPlanner-Basic') {
                    sh 'npm test || echo "Tests failed or skipped"'
                }
            }
        }
        stage('Build') {
            steps {
                dir('EventPlanner-Basic') {
                    sh 'npm run build || echo "No build script"'
                }
            }
        }
        stage('Docker Build') {
            steps {
                script {
                    sh 'docker build -t $DOCKER_IMAGE .'
                }
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploy stage - add deployment steps here.'
            }
        }
    }
    post {
        always {
            cleanWs()
        }
    }
}
